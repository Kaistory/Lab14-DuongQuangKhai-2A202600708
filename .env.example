# OPENAI SETTINGS
OPENAI_API_KEY=your_openai_api_key_here
# Model dùng khi provider=openai (mặc định gpt-4o)
OPENAI_MODEL=gpt-4o

# GEMINI SETTINGS
GEMINI_API_KEY=your_gemini_api_key_here
# Model dùng khi provider=google (mặc định gemini-3.1-flash-lite)
GEMINI_MODEL=gemini-3.1-flash-lite

# LOCAL LLM SETTINGS (GGUF via llama-cpp)
# Download model from: https://huggingface.co/microsoft/Phi-3-mini-4k-instruct-gguf
# Model đã được kèm sẵn ở thư mục gốc repo; có thể để ./models/... nếu bạn di chuyển nó.
LOCAL_MODEL_PATH=./Phi-3-mini-4k-instruct-q4.gguf
# GPU offload (cần bản llama-cpp-python build CUDA/Metal/Vulkan mới có tác dụng):
#   0  = chỉ CPU (mặc định)
#   -1 = offload toàn bộ layer lên GPU (nhanh nhất, cần đủ VRAM)
#   N  = offload N layer, phần còn lại chạy CPU (dùng khi VRAM ít, vd card 4 GB)
LOCAL_GPU_LAYERS=0
# Số token tối đa mỗi câu trả lời. Trên CPU đây là yếu tố chính quyết định độ trễ
# (256 ~ vài chục giây/câu; 1024 có thể mất vài phút). Tăng lên nếu cần câu dài hơn.
LOCAL_MAX_TOKENS=256

# LAB CONFIG
# Options: openai | google | local   (Lab 14 benchmark mặc định openai)
DEFAULT_PROVIDER=openai
# DEFAULT_MODEL: fallback cũ — nên dùng OPENAI_MODEL / GEMINI_MODEL ở trên thay thế.
# Chỉ có tác dụng khi tên model khớp tiền tố provider đang chạy (gpt* / gemini*).
DEFAULT_MODEL=gpt-4o
LOG_LEVEL=INFO
